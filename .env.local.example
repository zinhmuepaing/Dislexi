# Copy to .env.local and fill in. NO key here ever reaches client code —
# the browser only calls our own /api/* routes (ARCHITECTURE.md §4).

# ── TEMPORARY SUBSTITUTES (until Huawei Cloud access is confirmed) ──────────

# Azure AI Vision (Image Analysis 4.0 "Read") — substitutes Huawei Cloud OCR.
AZURE_VISION_KEY=            # Azure portal → your AI Vision (F0) resource → Keys and Endpoint → Key 1
AZURE_VISION_ENDPOINT=       # same page → Endpoint, e.g. https://<name>.cognitiveservices.azure.com

# Anthropic — substitutes Huawei Cloud MaaS for AI Tutoring + Telegram reviews.
ANTHROPIC_API_KEY=           # console.anthropic.com → API keys

# ── PERMANENT SERVICES ──────────────────────────────────────────────────────

# Azure Speech — TTS with wordBoundary highlight sync (browser SDK via short-lived token).
AZURE_SPEECH_KEY=            # Azure portal → Speech resource → Keys and Endpoint → Key 1
AZURE_SPEECH_REGION=         # e.g. southeastasia

# Supabase (Postgres) — server-side access only.
SUPABASE_URL=                # Supabase → Settings → API → Project URL
SUPABASE_SERVICE_ROLE_KEY=   # Supabase → Settings → API → service_role key (server-side ONLY, never the anon key)

# Telegram bot (webhook mode).
TELEGRAM_BOT_TOKEN=          # from @BotFather /newbot
TELEGRAM_WEBHOOK_SECRET=     # random string; also passed as secret_token to setWebhook (SETUP.md §3)
TELEGRAM_DEFAULT_CHAT_ID=    # family group chat id OR parent user id (parent must /start the bot once)
TELEGRAM_BOT_USERNAME=       # optional: bot @username without @ (e.g. DislexiBot); auto-fetched via getMe if unset. Used to detect @mentions in group chats.

# ── FUTURE SWAP TARGETS (Huawei Cloud — keep defined but unused) ─────────────
# Uncomment and fill when Huawei Cloud access is confirmed, then implement
# lib/huawei-iam.ts / lib/huawei-ocr.ts / lib/maas.ts per ARCHITECTURE.md §5.

# HUAWEI_IAM_USERNAME=       # IAM user name
# HUAWEI_IAM_PASSWORD=
# HUAWEI_IAM_DOMAIN=         # account/domain name
# HUAWEI_PROJECT_ID=         # project ID for the OCR region
# HUAWEI_OCR_ENDPOINT=       # e.g. ocr.ap-southeast-3.myhuaweicloud.com (confirm region in console)
# MAAS_API_KEY=              # ModelArts Studio API key (Bearer)
# MAAS_BASE_URL=https://api-ap-southeast-1.modelarts-maas.com/v1   # confirm region hostname in console
# MAAS_VISION_MODEL=         # vision-capable model id (Qwen-VL class). DeepSeek-V3.x is TEXT-ONLY.
# MAAS_TEXT_MODEL=deepseek-v3.1-terminus   # for Telegram review summaries (text-only is fine here)
